# ── Supabase (required) ─────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ── Admin dashboard password (required) ─────────────────────────────────────
# Used both client-side (login check) and server-side (API auth header).
# Choose a strong password — minimum 12 characters recommended.
NEXT_PUBLIC_ADMIN_PASSWORD=change-me-to-a-strong-password
