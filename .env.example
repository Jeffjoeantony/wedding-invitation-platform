# ── Supabase (required) ───────────────────────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ── Admin authentication (Supabase Auth) ────────────────────────────────────────────────────────
# Admin login uses Supabase Email+Password Auth. No env variable needed.
# Setup steps:
#   1. Supabase Dashboard → Authentication → Providers → Email → Enable
#   2. Supabase Dashboard → Authentication → Users → Create admin user
#   3. Run in SQL Editor:
#        CREATE TABLE admins (id uuid primary key default gen_random_uuid(),
#          email text unique not null, role text not null default 'admin',
#          created_at timestamptz default now());
#        INSERT INTO admins (email) VALUES ('your-admin@email.com');
#        ALTER TABLE admins ENABLE ROW LEVEL SECURITY;
#        CREATE POLICY "Service role only" ON admins USING (false);
#
# ── Invite media (gallery + guest moments) ─────────────────────────────────────
# Images are stored in Supabase Storage bucket `invite-media` (auto-created on
# first upload via SUPABASE_SERVICE_ROLE_KEY). No DB columns required.
# Optional: run db/migrations/media-schema.sql if public image URLs are blocked.
#
# ── Multi-event invitations (Engagement + Wedding, per-guest invite scope) ─────
# Required once: run db/migrations/multi-event-schema.sql in the Supabase SQL editor.
# Adds projects.events, guests.invited_to, guests.rsvp_by_event,
# guests.rsvp_headline, guests.greeting_line, guests.hide_greeting.

# ── Public site URL (WhatsApp / Open Graph previews) ───────────────────────────
# Absolute origin used for og:image on invite links. Set to your production URL
# (or custom domain). Falls back to VERCEL_URL when unset.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

